class TestLogger:
    def __init__(self):
        self.__log_dict = {}
        self.__failures_list = []
    
    def log(self, test_id, status):
        if test_id not in self.__log_dict:
            self.__log_dict[test_id] = {"pass_count": 0, "fail_count": 0}
        if(status == "PASS"):
            self.__log_dict[test_id]["pass_count"]+=1
        else:
            self.__log_dict[test_id]["fail_count"]+=1
            if test_id not in self.__failures_list:
                self.__failures_list.append(test_id)

    def get_failures(self):
        return self.__failures_list
    

    def get_pass_rate(self):
        pass_tests = 0
        fail_tests = 0
        for tests in self.__log_dict:
            pass_tests +=self.__log_dict[tests]["pass_count"]
            fail_tests += self.__log_dict[tests]["fail_count"]
        pass_rate= pass_tests/(pass_tests+fail_tests)
        if (pass_tests + fail_tests) == 0:
            return 0.0
        return round(pass_rate,2)

    def has_flaky(self, test_id):
        
        
        if test_id not in self.__log_dict:
            return False
        return (self.__log_dict[test_id]["pass_count"] > 0 and self.__log_dict[test_id]["fail_count"] > 0)





logger = TestLogger()
logger.log("test_001", "PASS")
logger.log("test_002", "FAIL")
logger.log("test_001", "FAIL")

print("Failures:", logger.get_failures())
print("Pass Rate:", logger.get_pass_rate())
print("Is test_001 flaky?", logger.has_flaky("test_001"))
print("Is test_002 flaky?", logger.has_flaky("test_002"))